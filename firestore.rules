rules_version = '2';
// ═══ LASTRO — Regras Firestore (F1: Membros & Convites) ═══
// Papéis: dono > admin > editor > leitor. A fronteira de segurança é AQUI.
// O aceite de convite é uma transação do cliente validada por get()/existsAfter():
// funciona no plano gratuito, sem Cloud Functions.
service cloud.firestore {
  match /databases/{database}/documents {

    function autenticado() { return request.auth != null; }
    function meuPapel(ws) {
      return get(/databases/$(database)/documents/workspaces/$(ws)/membros/$(request.auth.uid)).data.papel;
    }
    function souMembro(ws) {
      return autenticado()
        && exists(/databases/$(database)/documents/workspaces/$(ws)/membros/$(request.auth.uid));
    }
    function pelomenosEditor(ws) { return souMembro(ws) && meuPapel(ws) in ['dono','admin','editor']; }
    function pelomenosAdmin(ws)  { return souMembro(ws) && meuPapel(ws) in ['dono','admin']; }
    function souDono(ws)         { return souMembro(ws) && meuPapel(ws) == 'dono'; }
    function donoDoWs(ws) {
      return get(/databases/$(database)/documents/workspaces/$(ws)).data.criadoPor;
    }
    function convite(id) {
      return get(/databases/$(database)/documents/convites/$(id)).data;
    }

    match /workspaces/{ws} {
      // criar: autenticado, registrando-se como único membro-espelho
      allow create: if autenticado()
        && request.resource.data.criadoPor == request.auth.uid
        && request.resource.data.membrosUids == [request.auth.uid];

      allow get: if souMembro(ws);
      // LIST precisa ser provável pelo filtro da query (membrosUids)
      allow list: if autenticado() && request.auth.uid in resource.data.membrosUids;

      // update: admin+ (config, SEM tocar na posse) OU auto-entrada por convite
      // OU saída própria OU transferência de posse (só o dono, transacional).
      allow update: if (pelomenosAdmin(ws) && _posseIntacta())
        || _entradaPorConvite(ws)
        || _saidaPropria(ws)
        || _transferenciaDePosse(ws);
      allow delete: if souDono(ws);

      function _posseIntacta() {
        // F11: fecha o buraco em que um admin editava criadoPor e "roubava" o workspace
        return request.resource.data.criadoPor == resource.data.criadoPor;
      }
      function _transferenciaDePosse(ws) {
        // dono passa o bastão para um MEMBRO atual; os papéis trocam na mesma
        // transação (validado em /membros via getAfter) — nunca fica sem dono.
        return souDono(ws)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['criadoPor'])
          && request.resource.data.criadoPor != request.auth.uid
          && (request.resource.data.criadoPor in resource.data.membrosUids);
      }

      function _soMudouMembros() {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['membrosUids']);
      }
      function _entradaPorConvite(ws) {
        // adiciona exatamente o próprio uid; o doc de membro deve existir AO FIM
        // da transação (existsAfter) — e a criação desse doc, abaixo, exige um
        // convite válido. As duas regras se travam mutuamente.
        return autenticado()
          && _soMudouMembros()
          && !(request.auth.uid in resource.data.membrosUids)
          && (request.auth.uid in request.resource.data.membrosUids)
          && request.resource.data.membrosUids.size() == resource.data.membrosUids.size() + 1
          && request.resource.data.membrosUids.hasAll(resource.data.membrosUids)
          && existsAfter(/databases/$(database)/documents/workspaces/$(ws)/membros/$(request.auth.uid));
      }
      function _saidaPropria(ws) {
        // remove exatamente o próprio uid; dono não sai (posse não fica órfã)
        return souMembro(ws)
          && request.auth.uid != donoDoWs(ws)
          && _soMudouMembros()
          && !(request.auth.uid in request.resource.data.membrosUids)
          && request.resource.data.membrosUids.size() == resource.data.membrosUids.size() - 1
          && resource.data.membrosUids.hasAll(request.resource.data.membrosUids);
      }

      match /membros/{uid} {
        allow read: if souMembro(ws);

        // criar: (a) bootstrap — o criador grava a si mesmo como dono;
        //        (b) aceite de convite — válido, do mesmo ws, papel idêntico.
        allow create: if autenticado() && uid == request.auth.uid && (
          ( request.resource.data.papel == 'dono'
            && get(/databases/$(database)/documents/workspaces/$(ws)).data.criadoPor == request.auth.uid )
          ||
          ( request.resource.data.conviteId is string
            && convite(request.resource.data.conviteId).workspaceId == ws
            && convite(request.resource.data.conviteId).usado == false
            && convite(request.resource.data.conviteId).expiraEm > request.time.toMillis()
            && request.resource.data.papel == convite(request.resource.data.conviteId).papel )
        );

        // gerir papel: admin+; nunca a si mesmo; nunca o dono; nunca promover a
        // dono; admin não mexe em outro admin (só o dono pode).
        // F11: troca de posse — o dono promove o alvo a 'dono' e se rebaixa a
        // 'admin' na MESMA transação em que o workspace muda criadoPor
        // (getAfter amarra as três escritas).
        allow update: if ( pelomenosAdmin(ws)
          && uid != request.auth.uid
          && uid != donoDoWs(ws)
          && request.resource.data.papel in ['admin','editor','leitor']
          && (meuPapel(ws) == 'dono' || resource.data.papel != 'admin') )
          ||
          ( souDono(ws) && uid != request.auth.uid
            && request.resource.data.papel == 'dono'
            && getAfter(/databases/$(database)/documents/workspaces/$(ws)).data.criadoPor == uid )
          ||
          ( souDono(ws) && uid == request.auth.uid
            && request.resource.data.papel == 'admin'
            && getAfter(/databases/$(database)/documents/workspaces/$(ws)).data.criadoPor != request.auth.uid );

        // remover: admin+ com as mesmas proteções, OU sair (a si mesmo, exceto dono)
        allow delete: if
          ( pelomenosAdmin(ws)
            && uid != request.auth.uid
            && uid != donoDoWs(ws)
            && (meuPapel(ws) == 'dono' || resource.data.papel != 'admin') )
          ||
          ( autenticado() && uid == request.auth.uid && uid != donoDoWs(ws) );
      }

      // Núcleo financeiro (F2+)
      match /lancamentos/{id} { allow read: if souMembro(ws); allow write: if pelomenosEditor(ws); }
      match /contas/{id}      { allow read: if souMembro(ws); allow write: if pelomenosAdmin(ws); }
      match /cartoes/{id}     { allow read: if souMembro(ws); allow write: if pelomenosAdmin(ws); }
      match /categorias/{id}  { allow read: if souMembro(ws); allow write: if pelomenosAdmin(ws); }
      match /orcamentos/{id}  { allow read: if souMembro(ws); allow write: if pelomenosAdmin(ws); }
      match /metas/{id}       { allow read: if souMembro(ws); allow write: if pelomenosEditor(ws); }
      match /investimentos/{id} { allow read: if souMembro(ws); allow write: if pelomenosEditor(ws); } // F5
      match /recorrencias/{id}  { allow read: if souMembro(ws); allow write: if pelomenosEditor(ws); } // F7
    }

    match /convites/{id} {
      // criar: admin+ do workspace; nunca concede 'dono'; nasce não-usado
      allow create: if autenticado()
        && pelomenosAdmin(request.resource.data.workspaceId)
        && request.resource.data.papel in ['admin','editor','leitor']
        && request.resource.data.criadoPor == request.auth.uid
        && request.resource.data.usado == false;
      // abrir por id: o link contém um token aleatório não-enumerável;
      // list (gestão) só para admin+ do workspace do convite
      allow get: if autenticado();
      allow list: if autenticado() && pelomenosAdmin(resource.data.workspaceId);
      // marcar como usado: só o aceitante, só se ainda válido, só esses campos
      allow update: if autenticado()
        && resource.data.usado == false
        && request.time.toMillis() < resource.data.expiraEm
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usado','usadoPor'])
        && request.resource.data.usado == true
        && request.resource.data.usadoPor == request.auth.uid;
      // revogar: admin+ do workspace
      allow delete: if autenticado() && pelomenosAdmin(resource.data.workspaceId);
    }
  }
}
